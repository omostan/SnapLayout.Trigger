<Window x:Class="SnapLayout.Trigger.Example.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SnapLayout.Trigger Example" 
        Height="450" 
        Width="800"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1E1E1E">

    <Window.Resources>
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#505050"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#C50F1F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="#2D2D30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="SnapLayout.Trigger Example - Hover or Hold Maximize Button"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="10,0,0,0"
                       Foreground="White"
                       FontSize="12"/>

            <!-- Window Control Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="MinimizeButton"
                        Content="—"
                        Width="46"
                        Height="32"
                        Click="MinimizeButton_Click"
                        Style="{StaticResource WindowButtonStyle}"/>
                
                <Button x:Name="MaximizeButton"
                        Content="⬜"
                        Width="46"
                        Height="32"
                        Click="MaximizeButton_Click"
                        Style="{StaticResource WindowButtonStyle}"/>
                
                <Button x:Name="CloseButton"
                        Content="✕"
                        Width="46"
                        Height="32"
                        Click="CloseButton_Click"
                        Style="{StaticResource CloseButtonStyle}"/>
            </StackPanel>
        </Grid>

        <!-- Content Area -->
        <Grid Grid.Row="1" Background="#252526">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="SnapLayout.Trigger Demo Application" 
                           FontSize="24" 
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>
                
                <TextBlock Text="Try the following:" 
                           FontSize="16"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                
                <TextBlock FontSize="14" Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,5">
                    <Run Text="1. Hover over the Maximize button (⬜) - Snap Layout appears instantly"/>
                </TextBlock>
                
                <TextBlock FontSize="14" Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,5">
                    <Run Text="2. Click and hold the Maximize button - Snap Layout appears after 400ms"/>
                </TextBlock>
                
                <TextBlock FontSize="14" Foreground="#CCCCCC" HorizontalAlignment="Center" Margin="0,5">
                    <Run Text="3. Quick click the Maximize button - Normal maximize/restore behavior"/>
                </TextBlock>

                <Border Background="#3E3E42" 
                        Padding="20" 
                        Margin="0,30,0,0"
                        CornerRadius="5"
                        MaxWidth="600">
                    <StackPanel>
                        <TextBlock Text="About This Library" 
                                   FontSize="16" 
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock TextWrapping="Wrap" 
                                   Foreground="#CCCCCC"
                                   LineHeight="20">
                            SnapLayout.Trigger is a WPF library that brings Windows 11 Snap Layout functionality 
                            to custom window chrome. Simply call SnapLayoutTrigger.Initialize() with your maximize 
                            button to enable both mouse hover and mouse hold behaviors.
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
